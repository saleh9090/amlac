<IfModule mod_rewrite.c>
    RewriteEngine On

    # Root of the subdomain (dukan.techway.tech or dukan.techway.tech/) goes straight to the login page
    RewriteCond %{REQUEST_URI} ^/?$
    RewriteRule ^$ public/login [L]

    # Everything else forwards into the public/ folder as before
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
